<?xml version="1.0" encoding="utf-8"?>
<!-- nav_graph.xml -->
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/DashboardFragment">

    <fragment
        android:id="@+id/DashboardFragment"
        android:name="com.example.pesoai.ui.dashboard.DashboardFragment"
        android:label="Dashboard"
        tools:layout="@layout/fragment_dashboard"/>

    <fragment
        android:id="@+id/AnalyticsFragment"
        android:name="com.example.pesoai.ui.analytics.AnalyticsFragment"
        android:label="Analytics"
        tools:layout="@layout/fragment_analytics"/>

    <fragment
        android:id="@+id/TransactionsFragment"
        android:name="com.example.pesoai.ui.transactions.TransactionFragment"
        android:label="Transactions"
        tools:layout="@layout/fragment_transaction">
        <action
            android:id="@+id/action_transactions_to_recurring"
            app:destination="@id/RecurringFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_transactions_to_export"
            app:destination="@id/ExportTransactionsFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/RecurringFragment"
        android:name="com.example.pesoai.ui.recurring.RecurringFragment"
        android:label="Recurring"
        tools:layout="@layout/fragment_recurring"/>

    <fragment
        android:id="@+id/ExportTransactionsFragment"
        android:name="com.example.pesoai.ui.transactions.ExportTransactionsFragment"
        android:label="Export"
        tools:layout="@layout/fragment_export_transactions" />

    <fragment
        android:id="@+id/GoalsFragment"
        android:name="com.example.pesoai.ui.goals.SavingsGoalFragment"
        android:label="Goals"
        tools:layout="@layout/fragment_savings_goal"/>

    <fragment
        android:id="@+id/AdvisorFragment"
        android:name="com.example.pesoai.ui.chat.AIChatFragment"
        android:label="AI Advisor"
        tools:layout="@layout/fragment_ai_chat"/>

    <fragment
        android:id="@+id/ProfileFragment"
        android:name="com.example.pesoai.ui.profile.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile"/>

    <fragment
        android:id="@+id/SettingsFragment"
        android:name="com.example.pesoai.ui.settings.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings">

        <!-- FIX: BudgetCategoriesFragment registered here so NavController manages it -->
        <action
            android:id="@+id/action_settings_to_budgetCategories"
            app:destination="@id/BudgetCategoriesFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <!-- FIX: BudgetCategoriesFragment added as NavController destination -->
    <fragment
        android:id="@+id/BudgetCategoriesFragment"
        android:name="com.example.pesoai.ui.settings.BudgetCategoriesFragment"
        android:label="Budget Categories"
        tools:layout="@layout/fragment_budget_categories"/>

    <action
        android:id="@+id/action_global_to_notifications"
        app:destination="@id/NotificationsFragment"
        app:enterAnim="@anim/slide_in_right"
        app:exitAnim="@anim/slide_out_left"
        app:popEnterAnim="@anim/slide_in_left"
        app:popExitAnim="@anim/slide_out_right" />

    <fragment
        android:id="@+id/NotificationsFragment"
        android:name="com.example.pesoai.ui.notifications.NotificationsFragment"
        android:label="Notifications"
        tools:layout="@layout/fragment_notifications"/>

</navigation>