<?xml version="1.0" encoding="utf-8"?>
<!-- styles.xml -->
<resources>
    <!-- Custom Dialog Theme -->
    <style name="CustomDialogTheme" parent="Theme.Material3.Light.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.5</item>
    </style>

    <style name="BottomNavActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/primary_blue_light</item>
        <item name="shapeAppearanceOverlay">@style/BottomNavIndicatorShape</item>
    </style>

    <style name="BottomNavIndicatorShape">
        <item name="cornerSize">16dp</item>
    </style>

    <!-- Custom Dialog Theme -->
    <style name="CustomDialogTheme1" parent="Theme.Material3.Light.Dialog">
        <item name="colorPrimary">@color/primary_blue</item>
    </style>


</resources>