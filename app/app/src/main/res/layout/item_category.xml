<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/item_category.xml -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <!-- Emoji icon with tinted circle background -->
        <TextView
            android:id="@+id/tvCategoryIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:textSize="20sp"
            android:background="@drawable/bg_circle"
            android:backgroundTint="#607D8B" />

        <!-- Name + default badge -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvCategoryName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="?attr/colorOnSurface" />

            <TextView
                android:id="@+id/tvCategoryDefault"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_default_category"
                android:textSize="11sp"
                android:textColor="?attr/colorPrimary"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Edit button (always shown) -->
        <ImageButton
            android:id="@+id/btnEditCategory"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_edit"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/btn_edit_category" />

        <!-- Delete button (hidden for defaults) -->
        <ImageButton
            android:id="@+id/btnDeleteCategory"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/btn_delete_category"
            android:layout_marginStart="4dp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>