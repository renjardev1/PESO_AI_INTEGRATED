<?xml version="1.0" encoding="utf-8"?>
<!-- dialog_budget_blocked.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_rounded"
    android:padding="24dp">

    <!-- Icon badge — red to signal hard block -->
    <TextView
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center_horizontal"
        android:gravity="center"
        android:text="🚫"
        android:textSize="28sp"
        android:background="@drawable/circle_background_red"
        android:layout_marginBottom="16dp" />

    <!-- Title -->
    <TextView
        android:id="@+id/tvBlockedTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:textColor="#1A1A1A"
        android:textSize="20sp"
        android:textStyle="bold"
        android:text="@string/budget_blocked_title"
        android:layout_marginBottom="4dp" />

    <!-- Subtitle -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:textColor="#888888"
        android:textSize="13sp"
        android:text="@string/budget_blocked_subtitle"
        android:layout_marginBottom="16dp" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0F0F0"
        android:layout_marginBottom="16dp" />

    <!-- Budget row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">
        <TextView
            android:id="@+id/tvBlockedLimitLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/budget_label_monthly"
            android:textColor="#666666"
            android:textSize="13sp" />
        <TextView
            android:id="@+id/tvBlockedBudget"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#333333"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Spent row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/budget_label_spent"
            android:textColor="#666666"
            android:textSize="13sp" />
        <TextView
            android:id="@+id/tvBlockedSpent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#F44336"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Hint -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/budget_blocked_body_hint"
        android:textColor="#888888"
        android:textSize="12sp"
        android:layout_marginBottom="24dp" />

    <!-- OK button — full width, no cancel needed -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBlockedOk"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="@string/btn_ok"
        android:textColor="#FFFFFF"
        app:backgroundTint="#F44336"
        app:cornerRadius="10dp" />

</LinearLayout>