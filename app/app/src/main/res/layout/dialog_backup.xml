<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/dialog_backup.xml -->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="8dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="💾"
                android:textSize="28sp"
                android:gravity="center"
                android:background="@drawable/circle_background_green"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Data Backup &amp; Restore"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Manage your data"
                    android:textSize="13sp"
                    android:textColor="#757575"
                    android:layout_marginTop="2dp"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Last Backup Info -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E0E0E0"
            app:cardBackgroundColor="#F8F9FA">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Last Backup"
                    android:textSize="12sp"
                    android:textColor="#757575"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvLastBackupTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Never backed up"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Backup Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBackup"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:text="Backup Now"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textAllCaps="false"
            app:backgroundTint="#4CAF50"
            app:cornerRadius="12dp"
            app:icon="@android:drawable/ic_menu_save"
            app:iconTint="#FFFFFF"/>

        <!-- Restore Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRestore"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:text="Restore from Backup"
            android:textColor="#2196F3"
            android:textSize="15sp"
            android:textAllCaps="false"
            app:backgroundTint="#E3F2FD"
            app:cornerRadius="12dp"
            app:icon="@android:drawable/ic_menu_revert"
            app:iconTint="#2196F3"/>

        <!-- Cancel Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Cancel"
            android:textColor="#757575"
            android:textSize="15sp"
            android:textAllCaps="false"
            app:backgroundTint="#F5F5F5"
            app:cornerRadius="12dp"
            app:rippleColor="#E0E0E0"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
