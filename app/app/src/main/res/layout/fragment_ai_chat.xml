<?xml version="1.0" encoding="utf-8"?>
<!-- fragment_ai_chat.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_gray">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@color/card_white"
        android:elevation="2dp">

        <!-- Title Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="@string/ai_robot_emoji"
                android:textSize="24sp"
                android:gravity="center"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/ai_advisor_title"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginStart="12dp"/>

            <!-- History Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHistory"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_history"
                android:textColor="@color/primary_blue"
                android:textSize="13sp"
                app:icon="@android:drawable/ic_menu_recent_history"
                app:iconTint="@color/primary_blue"
                app:iconSize="18dp"/>

            <!-- New Chat Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNewChat"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_new_chat"
                android:textColor="@color/primary_blue"
                android:textSize="13sp"
                app:icon="@android:drawable/ic_menu_add"
                app:iconTint="@color/primary_blue"
                app:iconSize="18dp"/>

        </LinearLayout>

        <!-- Mode Toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="12dp">

            <TextView
                android:id="@+id/tvModeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mode_label"
                android:textSize="12sp"
                android:textColor="@color/text_primary"
                android:layout_marginEnd="8dp"/>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true"
                app:chipSpacing="8dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipGeneralMode"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/mode_general"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    app:chipBackgroundColor="@color/chip_mode_background"
                    app:chipStrokeColor="@color/primary_blue"
                    app:chipStrokeWidth="1dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAdvancedMode"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/mode_advanced"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    app:chipBackgroundColor="@color/chip_mode_background"
                    app:chipStrokeColor="@color/primary_blue"
                    app:chipStrokeWidth="1dp"/>

            </com.google.android.material.chip.ChipGroup>

        </LinearLayout>

    </LinearLayout>

    <!-- ═══════════════════════════════════════════════════════════════════════
         FIX B1: History Panel — added missing views referenced in AIChatFragment
         Views added: historyPanel, rvHistoryList, tvHistoryEmpty
         ═══════════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/historyPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/card_white"
        android:elevation="4dp"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/history_panel_title"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:padding="16dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvHistoryList"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:padding="8dp"
            android:clipToPadding="false"/>

        <TextView
            android:id="@+id/tvHistoryEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="24dp"
            android:text="@string/history_empty"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:visibility="gone"/>

    </LinearLayout>

    <!-- Chat Messages -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChatMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"
        android:clipToPadding="false"/>

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/emptyChatState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/chat_empty_emoji"
            android:textSize="48sp"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/chat_empty_title"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/chat_empty_subtitle"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginTop="8dp"/>

        <!-- Quick Prompts -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="24dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipPrompt1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="8dp"
                android:text="@string/quick_prompt_spending"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                app:chipBackgroundColor="@color/primary_blue_light"
                app:chipStrokeWidth="0dp"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipPrompt2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="8dp"
                android:text="@string/quick_prompt_budget"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                app:chipBackgroundColor="@color/primary_blue_light"
                app:chipStrokeWidth="0dp"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipPrompt3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/quick_prompt_savings"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                app:chipBackgroundColor="@color/primary_blue_light"
                app:chipStrokeWidth="0dp"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Loading Indicator -->
    <ProgressBar
        android:id="@+id/progressTyping"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_margin="8dp"
        android:visibility="gone"/>

    <!-- Input Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="@color/card_white"
        android:elevation="8dp"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/etMessage"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:hint="@string/chat_input_hint"
            android:textColorHint="@color/text_secondary"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:paddingHorizontal="16dp"
            android:background="@drawable/input_background"
            android:maxLines="3"/>

        <!-- FIX B2: renamed btnStopGeneration → btnStop to match AIChatFragment binding reference -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStop"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:visibility="gone"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:contentDescription="@string/btn_stop_description"
            app:icon="@android:drawable/ic_media_pause"
            app:iconTint="#FFFFFF"
            app:iconPadding="0dp"
            app:iconGravity="textStart"
            app:backgroundTint="@color/error_red"
            app:cornerRadius="24dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSend"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:contentDescription="@string/btn_send_description"
            app:icon="@android:drawable/ic_menu_send"
            app:iconTint="#FFFFFF"
            app:iconPadding="0dp"
            app:iconGravity="textStart"
            app:backgroundTint="@color/primary_blue"
            app:cornerRadius="24dp"/>

    </LinearLayout>

</LinearLayout>