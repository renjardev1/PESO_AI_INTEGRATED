<?xml version="1.0" encoding="utf-8"?>
<!-- item_history.xml -->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardHistory"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="#E0E0E0"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvConversationDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Today, 3:45 PM"
                android:textSize="12sp"
                android:textColor="#757575"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvExchangeCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3 exchanges"
                android:textSize="11sp"
                android:textColor="#9E9E9E"
                android:layout_marginEnd="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeleteHistory"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"
                app:icon="@android:drawable/ic_menu_delete"
                app:iconSize="16dp"
                app:iconTint="#F44336"
                app:iconGravity="textStart"
                app:iconPadding="0dp"/>

        </LinearLayout>

        <!-- User Message -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="You:"
            android:textSize="10sp"
            android:textColor="#2196F3"
            android:textStyle="bold"
            android:layout_marginBottom="2dp"/>

        <TextView
            android:id="@+id/tvUserMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="How much did I spend this month?"
            android:textSize="13sp"
            android:textColor="#1A1A1A"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginBottom="8dp"/>

        <!-- AI Response -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI:"
            android:textSize="10sp"
            android:textColor="#757575"
            android:textStyle="bold"
            android:layout_marginBottom="2dp"/>

        <TextView
            android:id="@+id/tvAIResponse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="You spent ₱15,000 this month..."
            android:textSize="12sp"
            android:textColor="#616161"
            android:maxLines="2"
            android:ellipsize="end"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>