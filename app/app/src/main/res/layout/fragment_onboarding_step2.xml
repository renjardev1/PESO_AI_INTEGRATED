<?xml version="1.0" encoding="utf-8"?>
<!-- fragment_onboarding_step2.xml -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_blue"
    android:padding="24dp">

    <!-- Back Button (top-left, matching step1/step3 design) -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/back"
        android:src="@drawable/ic_arrow_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#FFFFFF" />

    <!-- Step Progress (top-right) -->
    <TextView
        android:id="@+id/tvProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Step 2 of 3"
        android:textColor="#E0FFFFFF"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Content Card (fills space between top buttons and bottom button) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardSetup"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:layout_constraintBottom_toTopOf="@id/btnFinish"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnBack">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Icon -->
                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_gravity="center_horizontal"
                    android:contentDescription="@string/budget_icon"
                    android:src="@drawable/ic_savings"
                    app:tint="#2196F3" />

                <!-- Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="16dp"
                    android:text="Financial Information"
                    android:textColor="#333333"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <!-- Subtitle -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="Tell us about your income and financial goals"
                    android:textColor="#666666"
                    android:textSize="14sp" />

                <!-- ─── INCOME ──────────────────────────────────── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="6dp"
                    android:text="Monthly Income (₱)"
                    android:textColor="#333333"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilMonthlyIncome"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:boxBackgroundColor="#F5F5F5"
                    app:boxBackgroundMode="filled"
                    app:boxCornerRadiusBottomEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="0dp"
                    app:errorEnabled="true"
                    app:hintEnabled="false"
                    app:prefixText="₱ "
                    app:prefixTextColor="#2196F3">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etMonthlyIncome"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="e.g., 30000"
                        android:inputType="numberDecimal"
                        android:maxLines="1"
                        android:padding="14dp"
                        android:textColor="#000000"
                        android:textColorHint="#999999"
                        android:textSize="16sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- ─── MONTHLY SAVINGS TARGET (optional) ──────── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="6dp"
                    android:text="Monthly Savings Target (₱)  — optional"
                    android:textColor="#333333"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilSavingsTarget"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:boxBackgroundColor="#F5F5F5"
                    app:boxBackgroundMode="filled"
                    app:boxCornerRadiusBottomEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="0dp"
                    app:errorEnabled="true"
                    app:hintEnabled="false"
                    app:prefixText="₱ "
                    app:prefixTextColor="#2196F3">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etSavingsTarget"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="e.g., 5000"
                        android:inputType="numberDecimal"
                        android:maxLines="1"
                        android:padding="14dp"
                        android:textColor="#000000"
                        android:textColorHint="#999999"
                        android:textSize="16sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="💡 Tip: Experts recommend saving at least 20% of your income"
                    android:textColor="#666666"
                    android:textSize="12sp" />

                <!-- ─── FINANCIAL GOALS ─────────────────────────── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="8dp"
                    android:text="Financial Goals"
                    android:textColor="#333333"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <CheckBox
                    android:id="@+id/cbSavings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Build Emergency Savings"
                    android:textColor="#333333" />

                <CheckBox
                    android:id="@+id/cbInvestment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Investment Growth"
                    android:textColor="#333333" />

                <CheckBox
                    android:id="@+id/cbRetirement"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Retirement Planning"
                    android:textColor="#333333" />

                <CheckBox
                    android:id="@+id/cbDebtPayoff"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Pay Off Debt"
                    android:textColor="#333333" />

                <CheckBox
                    android:id="@+id/cbHomeOwnership"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Home Ownership"
                    android:textColor="#333333" />

                <!-- ─── RISK TOLERANCE ──────────────────────────── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="8dp"
                    android:text="Risk Tolerance"
                    android:textColor="#333333"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/rgRiskTolerance"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/rbConservative"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/risk_strict"
                        android:textColor="#333333" />

                    <RadioButton
                        android:id="@+id/rbModerate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/risk_balanced"
                        android:textColor="#333333" />

                    <RadioButton
                        android:id="@+id/rbAggressive"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/risk_flexible"
                        android:textColor="#333333" />

                </RadioGroup>

            </LinearLayout>
        </ScrollView>
    </com.google.android.material.card.MaterialCardView>

    <!-- Next Button (below card) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnFinish"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:enabled="false"
        android:text="Next"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        app:backgroundTint="#2196F3"
        app:cornerRadius="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
