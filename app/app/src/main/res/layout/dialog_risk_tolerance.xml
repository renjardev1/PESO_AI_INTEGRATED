<?xml version="1.0" encoding="utf-8"?>
<!-- dialog_risk_tolerance.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_rounded"
    android:padding="24dp">

    <!-- Icon -->
    <TextView
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center_horizontal"
        android:gravity="center"
        android:text="🛡️"
        android:textSize="28sp"
        android:background="@drawable/circle_background_blue"
        android:layout_marginBottom="16dp" />

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:textColor="#1A1A1A"
        android:textSize="20sp"
        android:textStyle="bold"
        android:text="@string/settings_risk_tolerance_title"
        android:layout_marginBottom="4dp" />

    <!-- Subtitle -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:textColor="#888888"
        android:textSize="13sp"
        android:text="@string/settings_risk_tolerance_subtitle"
        android:layout_marginBottom="16dp" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0F0F0"
        android:layout_marginBottom="16dp" />

    <!-- Radio options -->
    <RadioGroup
        android:id="@+id/rgRiskTolerance"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="24dp">

        <RadioButton
            android:id="@+id/rbConservative"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/risk_strict"
            android:textColor="#333333"
            android:paddingVertical="8dp" />

        <RadioButton
            android:id="@+id/rbModerate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/risk_balanced"
            android:textColor="#333333"
            android:paddingVertical="8dp" />

        <RadioButton
            android:id="@+id/rbAggressive"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/risk_flexible"
            android:textColor="#333333"
            android:paddingVertical="8dp" />

    </RadioGroup>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRiskCancel"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="@string/btn_cancel"
            android:textColor="#757575"
            app:strokeColor="#CCCCCC"
            app:cornerRadius="10dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRiskSave"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="@string/btn_save_changes"
            android:textColor="#FFFFFF"
            app:backgroundTint="#2196F3"
            app:cornerRadius="10dp" />

    </LinearLayout>

</LinearLayout>