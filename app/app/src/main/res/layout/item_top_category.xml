<?xml version="1.0" encoding="utf-8"?>
<!-- item_top_category.xml -->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="#E0E0E0"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvCategoryIcon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="🍔"
            android:textSize="20sp"
            android:gravity="center"
            android:background="@drawable/circle_background_orange"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvCategoryName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Food &amp; Dining"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"/>

            <TextView
                android:id="@+id/tvTransactionCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="24 transactions"
                android:textSize="12sp"
                android:textColor="#757575"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₱"
            android:textSize="14sp"
            android:textColor="#1A1A1A"
            android:layout_marginEnd="2dp"/>

        <TextView
            android:id="@+id/tvCategoryTotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="8,450"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
